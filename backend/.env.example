# Copy to `.env` and fill in. Never commit real secrets.

# MEGA (document vault)
# MEGA_EMAIL=
# MEGA_PASSWORD=

# Google Drive vault blobs — see services/googleDriveStorage.ts
# GDRIVE_MASTER_FOLDER_ID=
# GDRIVE_CLIENT_EMAIL=
# GDRIVE_PRIVATE_KEY=
# Optional: path to service account JSON (defaults search for kryptes-storage-bot.json)
# GDRIVE_CREDENTIALS_PATH=
