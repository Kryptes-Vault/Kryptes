# GDRIVE_MASTER_FOLDER_ID=

# Logical folder name under the master folder for Document Locker files (one subfolder per value):
# GDRIVE_DOCUMENTS_USER_ID=kryptes-documents

# Option A — inline service account (use \n for newlines in the private key):
# GDRIVE_CLIENT_EMAIL=your-sa@project.iam.gserviceaccount.com
# GDRIVE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Option B — path to JSON (e.g. repo root kryptes-storage-bot.json):
# GDRIVE_CREDENTIALS_PATH=../kryptes-storage-bot.json

# Startup: verify JWT + Drive API (about.get). Set false to skip.
# GDRIVE_STARTUP_VERIFY=true
# On verify failure, exit process unless false (default: exit).
# GDRIVE_STARTUP_FAIL_FAST=true
