{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["node"],
    "outDir": "dist",
    "rootDir": "."
  },
  "include": ["server.ts", "routes/**/*.ts", "config/**/*.ts", "services/**/*.ts", "models/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
